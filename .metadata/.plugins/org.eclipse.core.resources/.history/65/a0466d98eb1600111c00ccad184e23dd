/* USER CODE BEGIN 0 */
void playSong() {
    HAL_GPIO_WritePin(GPIOA, GPIO_PIN_5, GPIO_PIN_SET);
    isPlaying = 1;
    int length = sizeof(song)/sizeof(song[0]);
    for (int i = 0; i < length; i++) {
        __HAL_TIM_SET_AUTORELOAD(&htim1, song[i].tone);
        __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_2, song[i].tone/2);
        __HAL_TIM_SET_COUNTER(&htim1, 0);

        HAL_TIM_PWM_Start(&htim1, TIM_CHANNEL_2);

        // ENABLE THE ADVANCED TIMER MAIN OUTPUT:
        __HAL_TIM_MOE_ENABLE(&htim1);

        HAL_Delay(song[i].duration * current_tempo);

        HAL_TIM_PWM_Stop(&htim1, TIM_CHANNEL_2);
    }
    isPlaying = 0;
    HAL_GPIO_WritePin(GPIOA, GPIO_PIN_5, GPIO_PIN_RESET);
}

void HAL_ADC_ConvCpltCallback(ADC_HandleTypeDef* hadc) {
    float voltage = adc_dma_buffer*3.3/4096.0;
    char string[17];
//    snprintf(string, sizeof(string), "Voltage: %.3f V", voltage);
//    lcd_println(string, 0);
//    int bar = voltage * 80 / 3.3;
//    lcd_drawBar(bar);

    // MAP ADC VALUE TO TEMPO
    // Example: Map 0-4095 to a delay multiplier of 20ms to 200ms
    // The lower the ADC value, the faster the song (or vice versa, customize as needed)
    current_tempo = 20 + ((adc_dma_buffer * 180) / 4095);
}
volatile uint8_t play_request = 0; // Add this to your Private Variables (PV)

void HAL_GPIO_EXTI_Callback(uint16_t GPIO_Pin) {
    // Change GPIO_PIN_8 to B1_Pin
    if (GPIO_Pin == B1_Pin) {
        uint32_t tick = HAL_GetTick();
        uint32_t delta = tick - last_tick;
        if (!isPlaying && delta >= DEBOUNCE) {
            play_request = 1;
            last_tick = HAL_GetTick();
        }
    }
}
